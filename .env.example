# ═══════════════════════════════════════════════════
# VELTRIX BOT — Configuration
# ═══════════════════════════════════════════════════

# 1. Va sur https://discord.com/developers/applications
# 2. Crée une application > Bot > Copie le token
DISCORD_TOKEN=ton_token_ici

# 3. Clique sur "OAuth2" > copie le Client ID
CLIENT_ID=ton_client_id_ici

# 4. Clic droit sur ton serveur Discord > "Copier l'identifiant du serveur"
GUILD_ID=ton_guild_id_ici

# 5. Crée un channel privé staff et copie son ID
STAFF_CHANNEL_ID=id_du_channel_staff

# 6. ID du rôle A&R qui sera ping sur les nouvelles démos
AR_ROLE_ID=id_du_role_ar

# 7. ID du rôle Staff (accès aux salons de release)
STAFF_ROLE_ID=id_du_role_staff

# 8. ID de la catégorie "Waiting for Release"
RELEASE_CATEGORY_ID=id_de_la_categorie
